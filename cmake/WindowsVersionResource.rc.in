#include <winres.h>

#define VER_FILEVERSION             @PLATFORMER_APP_VERSION_MAJOR@,@PLATFORMER_APP_VERSION_MINOR@,@PLATFORMER_APP_VERSION_PATCH@,@PLATFORMER_APP_VERSION_BUILD@
#define VER_PRODUCTVERSION          @PLATFORMER_APP_VERSION_MAJOR@,@PLATFORMER_APP_VERSION_MINOR@,@PLATFORMER_APP_VERSION_PATCH@,@PLATFORMER_APP_VERSION_BUILD@
#define VER_FILEVERSION_STR         "@WINDOWS_RESOURCE_FILE_VERSION@\0"
#define VER_PRODUCTVERSION_STR      "@WINDOWS_RESOURCE_PRODUCT_VERSION@\0"

IDI_APP_ICON ICON "@WINDOWS_RESOURCE_ICON_FILE@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION VER_FILEVERSION
 PRODUCTVERSION VER_PRODUCTVERSION
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Benno111\0"
            VALUE "FileDescription", "@WINDOWS_RESOURCE_FILE_DESCRIPTION@\0"
            VALUE "FileVersion", VER_FILEVERSION_STR
            VALUE "InternalName", "@WINDOWS_RESOURCE_INTERNAL_NAME@\0"
            VALUE "OriginalFilename", "@WINDOWS_RESOURCE_ORIGINAL_FILENAME@\0"
            VALUE "ProductName", "@WINDOWS_RESOURCE_PRODUCT_NAME@\0"
            VALUE "ProductVersion", VER_PRODUCTVERSION_STR
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
